@page "/"
@page "/scan"
@inject IJSRuntime JS
@inject Services.MockRedemptionService RedemptionService
@inject HttpClient Http
@inject NavigationManager Nav

<PageTitle>Scan QR Code</PageTitle>

<div class="scan-page">
    <header class="scan-header">
        <div class="logo"><img src="/assets/culvers-logo.svg" alt="Culver's logo" class="culvers-logo" /></div>
        <button class="close-btn" @onclick="Close">✕</button>
    </header>

    <main class="scan-main">
        <div class="scan-viewport" aria-live="polite">
            <div class="video-wrapper">
                @if (scanState == ScanState.PreScan)
                {
                    <div class="qr-graphic" aria-hidden="true">
                        <img src="/assets/qr-graphic.svg" alt="QR graphic" class="qr-icon" />
                    </div>
                }
                else if (scanState == ScanState.Scanning)
                {
                    <video id="qr-video" autoplay muted playsinline class="scan-video"></video>
                    <div class="scan-frame" aria-hidden="true"></div>
                }
                else
                {
                    <div class="qr-graphic" aria-hidden="true">
                        <img src="/assets/qr-graphic.svg" alt="QR graphic" class="qr-icon" />
                    </div>
                }

                @if (scanState == ScanState.Success)
                {
                    <div class="scan-success-overlay" aria-live="assertive">
                        <div class="scan-success-card">
                            <div class="success-icon">✓</div>
                            <div class="success-title">SUCCESS</div>
                            <div class="success-copy">Your QR code has been scanned and redeemed.</div>
                            <button class="btn btn-primary btn-scan btn-success-action" @onclick="ResetScan">Scan Another Code</button>
                        </div>
                    </div>
                }
                else if (scanState == ScanState.Invalid)
                {
                    <div class="scan-invalid-overlay" aria-live="assertive">
                        <div class="scan-invalid-card">
                            <div class="invalid-icon">✕</div>
                            <div class="invalid-title">INVALID CODE</div>
                            <div class="invalid-copy">The code you entered is not valid. Try scanning again or enter the reward code manually.</div>
                            <button class="btn btn-invalid-action" @onclick="ResetScan">SCAN ANOTHER CODE</button>
                            <button class="btn btn-link invalid-link" @onclick="EnterCodeManually">Enter Code Manually</button>
                        </div>
                    </div>
                }
            </div>
        </div>

        <h2 class="scan-title">SCAN REWARD</h2>
        <p class="scan-copy">Scan Delicious Rewards user reward code. Upon successful scan, distribute VIP merch.</p>

        @if (scanState == ScanState.ManualInput)
        {
            <div class="manual-entry-card">
                <div class="input-label">INPUT REWARD</div>
                <input class="form-control manual-code-input" @bind="manualCode" placeholder="Enter reward code" />
                <button class="btn btn-primary btn-scan" @onclick="SubmitManualCode" disabled="@string.IsNullOrWhiteSpace(manualCode)">CONTINUE</button>
                <button class="btn btn-link manual-link" @onclick="ResetScan">Scan Another Code</button>
            </div>

            <div class="scan-status">@statusMessage</div>
        }
        else if (scanState != ScanState.Success)
        {
            <div class="scan-actions">
                <button class="btn btn-primary btn-scan" @onclick="StartScan" disabled="@(scanState == ScanState.Scanning)">@((scanState == ScanState.Scanning) ? "Scanning..." : "SCAN QR CODE")</button>
                <button class="btn btn-link manual-link" @onclick="EnterCodeManually">Enter Code Manually</button>
            </div>

            <div class="scan-status">@statusMessage</div>
        }
        else
        {
            <div class="scan-status scan-status-success">@statusMessage</div>
        }
    </main>
</div>

@code {
    private string statusMessage = "Ready to scan.";
    private string manualCode = string.Empty;
    private Services.RedemptionResponse? scanResult;
    private ScanState scanState = ScanState.PreScan;

    private async Task StartScan()
    {
        if (scanState == ScanState.Scanning)
        {
            statusMessage = "Already scanning...";
            return;
        }

        scanState = ScanState.Scanning;
        statusMessage = "Requesting camera access...";
        await InvokeAsync(StateHasChanged);
        await Task.Yield();
        await Task.Delay(200);

        try
        {
            var qrCode = await JS.InvokeAsync<string?>("qrScanner.startScanner");
            if (string.IsNullOrWhiteSpace(qrCode))
            {
                statusMessage = "No QR code detected. Please try again.";
                scanState = ScanState.PreScan;
                return;
            }

            statusMessage = "Processing redemption...";
            try
            {
                var rnd = new Random();
                var successUrl = "https://test-api.culvers.com/punchh/Mock/checkoffsiteredeemable-success";
                var failUrl = "https://test-api.culvers.com/punchh/Mock/checkoffsiteredeemable-fail";
                var targetUrl = (rnd.Next(2) == 0) ? successUrl : failUrl;

                var request = new HttpRequestMessage(HttpMethod.Post, targetUrl);
                request.Headers.Add("Ocp-Apim-Subscription-Key", "22f000af3faa43f783da93d214d82e96");
                request.Content = JsonContent.Create(new { QRCode = qrCode });

                var resp = await Http.SendAsync(request);
                if (resp.IsSuccessStatusCode)
                {
                    var parsed = await resp.Content.ReadFromJsonAsync<Services.RedemptionResponse>();
                    if (parsed is not null)
                    {
                        scanResult = parsed;
                    }
                    else
                    {
                        scanResult = await RedemptionService.RedeemAsync(qrCode);
                    }
                }
                else
                {
                    scanResult = await RedemptionService.RedeemAsync(qrCode);
                }
            }
            catch
            {
                scanResult = await RedemptionService.RedeemAsync(qrCode);
            }

            scanState = scanResult.IsValid ? ScanState.Success : ScanState.Invalid;
            statusMessage = scanResult.IsValid ? "Scan complete." : "Invalid code.";
        }
        catch (JSException ex)
        {
            statusMessage = $"Camera access failed: {ex.Message}";
            scanState = ScanState.PreScan;
        }
        catch (Exception ex)
        {
            statusMessage = $"An error occurred: {ex.Message}";
            scanState = ScanState.PreScan;
        }
        finally
        {
            if (scanState != ScanState.Success)
            {
                await JS.InvokeVoidAsync("qrScanner.stopScanner");
            }
        }
    }

    private async Task SubmitManualCode()
    {
        if (string.IsNullOrWhiteSpace(manualCode))
        {
            statusMessage = "Enter a reward code to continue.";
            return;
        }

        scanState = ScanState.Scanning;
        statusMessage = "Processing manual code...";
        await InvokeAsync(StateHasChanged);
        await Task.Yield();
        await Task.Delay(100);

        try
        {
            scanResult = await RedemptionService.RedeemAsync(manualCode.Trim());
            scanState = scanResult.IsValid ? ScanState.Success : ScanState.Invalid;
            statusMessage = scanResult.IsValid ? "Redemption complete." : "Invalid code.";
        }
        catch (Exception ex)
        {
            statusMessage = $"An error occurred: {ex.Message}";
            scanState = ScanState.PreScan;
        }
    }

    private async Task ResetScan()
    {
        scanState = ScanState.PreScan;
        statusMessage = "Ready to scan.";
        manualCode = string.Empty;
        scanResult = null;
        await JS.InvokeVoidAsync("qrScanner.stopScanner");
    }

    private Task EnterCodeManually()
    {
        manualCode = string.Empty;
        scanResult = null;
        scanState = ScanState.ManualInput;
        statusMessage = "Enter code manually.";
        return Task.CompletedTask;
    }

    private void Close()
    {
        Nav.NavigateTo("/");
    }

    private enum ScanState
    {
        PreScan,
        Scanning,
        ManualInput,
        Success,
        Invalid
    }
}
